export ZSH="$HOME/.oh-my-zsh"

# Minimal prompt — path is shown in the web UI footer via OSC 7
ZSH_THEME=""
PROMPT='> '
RPROMPT=''

plugins=(git extract z)
[[ -d $ZSH/custom/plugins/zsh-autosuggestions ]] && plugins+=(zsh-autosuggestions)
[[ -d $ZSH/custom/plugins/zsh-syntax-highlighting ]] && plugins+=(zsh-syntax-highlighting)

source $ZSH/oh-my-zsh.sh

# ── OSC 7 — report CWD to the web UI footer on every prompt ──────────────────
# Consumed by xterm.js parser.registerOscHandler(7, ...) in index.html
_osc7_report() {
  if [[ -n "$TMUX" ]]; then
    # DCS passthrough: tmux unwraps this and forwards the inner OSC 7 to the terminal
    printf "\033Ptmux;\033\033]7;file://%s%s\007\033\\" "${HOST:-localhost}" "$PWD"
  else
    printf "\033]7;file://%s%s\033\\" "${HOST:-localhost}" "$PWD"
  fi
}

# ── Hooks ─────────────────────────────────────────────────────────────────────
precmd() {
  _osc7_report
  if [[ -n "$TMUX" ]]; then
    tmux rename-window "$(basename "$PWD")" 2>/dev/null
  fi
}
preexec() {
  if [[ -n "$TMUX" ]]; then
    tmux rename-window "${${1%% *}##*/}" 2>/dev/null
  fi
}

# roost wrapper — intercepts gh copilot calls and logs to SQLite
[ -f /root/.roost/bin/roost-wrap ] && source /root/.roost/bin/roost-wrap

# ── User config ───────────────────────────────────────────────────────────────
# Edit ~/.roost/config/zshrc.local for aliases, exports, extra plugins, etc.
# This file lives on the host volume — no rebuild needed.
[ -f /root/.roost/config/zshrc.local ] && source /root/.roost/config/zshrc.local
