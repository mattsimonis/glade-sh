export ZSH="$HOME/.oh-my-zsh"

ZSH_THEME="eastwood"
PROMPT='> '
RPROMPT=''

# zsh-syntax-highlighting MUST be last — it hooks ZLE widgets
plugins=(
  git
  extract
  z
  zsh-autosuggestions
  zsh-syntax-highlighting
)

source $ZSH/oh-my-zsh.sh

_osc7_report() {
  if [[ -n "$TMUX" ]]; then
    printf "\033Ptmux;\033\033]7;file://%s%s\007\033\\" "${HOST:-localhost}" "$PWD"
  else
    printf "\033]7;file://%s%s\033\\" "${HOST:-localhost}" "$PWD"
  fi
}

precmd() {
  _osc7_report
  [[ -n "$TMUX" ]] && tmux rename-window "$(basename "$PWD")" 2>/dev/null
}
preexec() {
  [[ -n "$TMUX" ]] && tmux rename-window "${${1%% *}##*/}" 2>/dev/null
}

[ -f /root/.glade/bin/glade-wrap ] && source /root/.glade/bin/glade-wrap
[ -f /root/.glade/config/zshrc.local ] && source /root/.glade/config/zshrc.local
