# Roost — local configuration
# Copy to .env and edit before running `make setup` or `docker compose up`.
#
#   cp .env.example .env

# ── Host machine ──────────────────────────────────────────────────────────────

# Hostname or IP of the machine running Docker.
# Used by `make deploy-web` and printed in setup instructions.
HOST=mac-mini

# Domain name for the web UI (must match your Caddy/DNS config).
DOMAIN=roost.local

# ── App repo ──────────────────────────────────────────────────────────────────

# Git repo URL for the app. The container clones this on first start and
# polls for updates every 2 minutes. Override if you're using a fork.
# ROOST_REPO_URL=https://github.com/mattsimonis/roost.git



# Where Roost stores its data: DB, logs, uploaded images.
# Created automatically on first run. Change this if you want data elsewhere.
ROOST_DIR=~/.roost

# ── Personal volume mounts ────────────────────────────────────────────────────
# To mount your code directory inside the container, create a gitignored
# docker-compose.override.yml (do not edit docker-compose.yml for this):
#
#   services:
#     ttyd:
#       volumes:
#         - /your/dev/dir:/mnt/dev
