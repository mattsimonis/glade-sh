# Glade — web container file server
# Serves the HTML wrapper and static assets for caddy-proxy to front.
# Mounted into the glade-web container at /etc/caddy/Caddyfile.

:7682 {
	encode zstd gzip

	# API proxy — routes to ttyd container (API runs there now)
	handle /api/* {
		reverse_proxy glade-ttyd:7683 {
			flush_interval -1
		}
	}

	# Assets (fonts, etc.) — long cache, they never change
	handle /assets/* {
		root * /srv
		file_server
	}

	# Icons — serve directly without try_files fallback.
	# try_files would return index.html (200) for missing icons, which iOS and
	# the service worker would cache as a valid response — silently breaking
	# the home screen icon forever until the SW cache is manually cleared.
	handle /icons/* {
		root * /srv/web
		file_server
	}

	# Bare apple-touch-icon URLs that iOS Safari checks as a fallback
	# before giving up (no <link> tags needed).
	handle /apple-touch-icon.png {
		redir /icons/icon-180.png 302
	}
	handle /apple-touch-icon-precomposed.png {
		redir /icons/icon-180.png 302
	}

	# HTML wrapper — never cache so mobile browsers always get latest
	handle {
		root * /srv/web
		file_server
		try_files {path} /index.html
	}

	header {
		-X-Frame-Options
		-Server
		X-Content-Type-Options nosniff
	}

	# No-cache for HTML and manifest so iOS always fetches fresh metadata
	@nocache {
		path / /index.html /manifest.json /sw.js
	}
	header @nocache Cache-Control "no-cache, must-revalidate"

	# No-cache for icons too — rebrand/icon updates should be immediate
	@icons {
		path /icons/*
	}
	header @icons Cache-Control "no-cache, must-revalidate"
}

