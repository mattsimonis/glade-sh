fizzy.home {
reverse_proxy fizzy-web-1:3000
tls /etc/caddy/certs/fizzy.home.pem /etc/caddy/certs/fizzy.home-key.pem
}

yoto.home {
reverse_proxy yoto-home:3000
tls /etc/caddy/certs/yoto.home.pem /etc/caddy/certs/yoto.home-key.pem
}

# Glade — plain HTTP via mDNS (glade.local on port 80, no cert needed)
http://glade.local {
@ttyd_proxy path_regexp tport /ttyd/(\d{4,5})(/.*)?
handle @ttyd_proxy {
uri strip_prefix /ttyd/{http.regexp.tport.1}
reverse_proxy glade-ttyd:{http.regexp.tport.1} {
header_up X-Forwarded-Proto {scheme}
flush_interval -1
transport http {
versions 1.1
read_timeout  0
write_timeout 0
}
}
}
handle {
reverse_proxy glade-web:7682
}
header {
-X-Frame-Options
X-Content-Type-Options nosniff
Referrer-Policy strict-origin-when-cross-origin
}
}

# Glade — HTTPS via Pi-hole DNS (glade.local)
glade.local {
@ttyd_proxy path_regexp tport /ttyd/(\d{4,5})(/.*)?
handle @ttyd_proxy {
uri strip_prefix /ttyd/{http.regexp.tport.1}
reverse_proxy glade-ttyd:{http.regexp.tport.1} {
header_up X-Forwarded-Proto {scheme}
flush_interval -1
transport http {
versions 1.1
read_timeout  0
write_timeout 0
}
}
}
handle {
reverse_proxy glade-web:7682
}
tls /etc/caddy/certs/glade.local.pem /etc/caddy/certs/glade.local-key.pem
header {
-X-Frame-Options
X-Content-Type-Options nosniff
Referrer-Policy strict-origin-when-cross-origin
}
}
