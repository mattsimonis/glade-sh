fizzy.home {
reverse_proxy fizzy-web-1:3000
tls /etc/caddy/certs/fizzy.home.pem /etc/caddy/certs/fizzy.home-key.pem
}

yoto.home {
reverse_proxy yoto-home:3000
tls /etc/caddy/certs/yoto.home.pem /etc/caddy/certs/yoto.home-key.pem
}

# Roost — plain HTTP via mDNS (casper.local on port 80, no cert needed)
http://casper.local {
@ttyd_proxy path_regexp tport /ttyd/(\d{4,5})(/.*)?
handle @ttyd_proxy {
uri strip_prefix /ttyd/{http.regexp.tport.1}
reverse_proxy roost-ttyd:{http.regexp.tport.1} {
header_up X-Forwarded-Proto {scheme}
flush_interval -1
transport http {
versions 1.1
read_timeout  0
write_timeout 0
}
}
}
handle {
reverse_proxy roost-web:7682
}
header {
-X-Frame-Options
X-Content-Type-Options nosniff
Referrer-Policy strict-origin-when-cross-origin
}
}

# Roost — HTTPS via Pi-hole DNS (ai.home)
ai.home {
@ttyd_proxy path_regexp tport /ttyd/(\d{4,5})(/.*)?
handle @ttyd_proxy {
uri strip_prefix /ttyd/{http.regexp.tport.1}
reverse_proxy roost-ttyd:{http.regexp.tport.1} {
header_up X-Forwarded-Proto {scheme}
flush_interval -1
transport http {
versions 1.1
read_timeout  0
write_timeout 0
}
}
}
handle {
reverse_proxy roost-web:7682
}
tls /etc/caddy/certs/ai.home.pem /etc/caddy/certs/ai.home-key.pem
header {
-X-Frame-Options
X-Content-Type-Options nosniff
Referrer-Policy strict-origin-when-cross-origin
}
}
