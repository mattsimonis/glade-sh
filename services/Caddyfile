fizzy.home {
reverse_proxy fizzy-web-1:3000
tls /etc/caddy/certs/fizzy.home.pem /etc/caddy/certs/fizzy.home-key.pem
}

yoto.home {
reverse_proxy yoto-home:3000
tls /etc/caddy/certs/yoto.home.pem /etc/caddy/certs/yoto.home-key.pem
}

# Glade — plain HTTP fallback
# Handles http:// requests if a client skips TLS. Requires a Pi-hole A record
# for the domain pointing to the host's Tailscale IP. Replace glade.home below
# with whatever you set DOMAIN= to in your .env file.
http://glade.home {
@ttyd_proxy path_regexp tport /ttyd/(\d{4,5})(/.*)?
handle @ttyd_proxy {
uri strip_prefix /ttyd/{http.regexp.tport.1}
reverse_proxy glade-ttyd:{http.regexp.tport.1} {
header_up X-Forwarded-Proto {scheme}
flush_interval -1
transport http {
versions 1.1
read_timeout  0
write_timeout 0
}
}
}
handle {
reverse_proxy glade-web:7682
}
header {
-X-Frame-Options
X-Content-Type-Options nosniff
Referrer-Policy strict-origin-when-cross-origin
}
}

# Glade — HTTPS
# Replace glade.home with whatever you set DOMAIN= to in your .env file.
# Requires a Pi-hole A record pointing the domain to the host's Tailscale IP,
# and a matching mkcert TLS cert.
glade.home {
@ttyd_proxy path_regexp tport /ttyd/(\d{4,5})(/.*)?
handle @ttyd_proxy {
uri strip_prefix /ttyd/{http.regexp.tport.1}
reverse_proxy glade-ttyd:{http.regexp.tport.1} {
header_up X-Forwarded-Proto {scheme}
flush_interval -1
transport http {
versions 1.1
read_timeout  0
write_timeout 0
}
}
}
handle {
reverse_proxy glade-web:7682
}
tls /etc/caddy/certs/glade.home.pem /etc/caddy/certs/glade.home-key.pem
header {
-X-Frame-Options
X-Content-Type-Options nosniff
Referrer-Policy strict-origin-when-cross-origin
}
}
